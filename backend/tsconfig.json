{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*",
    "scripts/**/*",
    "prisma/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/controllers/aiStudyBuddyController.ts",
    "src/controllers/aiTeacherAssistantController.ts",
    "src/controllers/voiceAttendanceController.ts",
    "src/controllers/aiParentEngagementController.ts",
    "src/services/aiStudyBuddyService.ts",
    "src/services/voiceAttendanceService.ts",
    "src/services/aiParentEngagementService.ts",
    "src/services/aiLessonPlannerService.ts",
    "src/routes/aiStudyBuddy.ts",
    "src/routes/aiTeacherAssistant.ts",
    "src/routes/voiceAttendance.ts",
    "src/routes/aiTeacherAssistantRoutes.ts",
    "src/routes/voiceAttendanceRoutes.ts",
    "src/routes/aiParentEngagementRoutes.ts"
  ]
}